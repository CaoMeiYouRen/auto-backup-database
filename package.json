{
  "name": "auto-backup-database",
  "version": "1.0.0",
  "description": "服务器数据库自动备份方案，支持本地备份和异地备份",
  "author": "CaoMeiYouRen",
  "private": true,
  "license": "MIT",
  "bin": {
    "auto-backup-database": "./dist/cli.mjs",
    "abd": "./dist/cli.mjs"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "release": "semantic-release",
    "lint": "cross-env NODE_ENV=production eslint . --fix",
    "prebuild": "rimraf dist",
    "build": "cross-env NODE_ENV=production tsdown",
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "dev:tsdown": "cross-env NODE_ENV=development tsdown --watch",
    "start": "node ./dist/index",
    "start:tsx": "cross-env NODE_ENV=production tsx src/index.ts",
    "commit": "cz",
    "prepare": "husky",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.3.0",
    "@vercel/nft": "^1.3.2",
    "commitizen": "^4.3.1",
    "commitlint": "^20.4.2",
    "commitlint-config-cmyr": "^1.0.0",
    "cross-env": "^10.0.0",
    "cz-conventional-changelog-cmyr": "^2.0.0",
    "debug": "^4.4.3",
    "eslint": "^9.34.0",
    "eslint-config-cmyr": "^2.1.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "rimraf": "^6.1.3",
    "semantic-release": "^25.0.3",
    "semantic-release-cmyr-config": "^1.0.1",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.0.5",
    "vitest": "^4.0.18"
  },
  "config": {},
  "lint-staged": {
    "*.{js,ts}": [
      "npm run lint",
      "git add"
    ]
  },
  "keywords": [
    "auto",
    "backup",
    "database",
    "sqlite",
    "mysql",
    "postgresql",
    "mongodb",
    "typescript"
  ],
  "homepage": "https://github.com/CaoMeiYouRen/auto-backup-database#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CaoMeiYouRen/auto-backup-database.git"
  },
  "bugs": {
    "url": "https://github.com/CaoMeiYouRen/auto-backup-database/issues"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.996.0",
    "better-bytes": "^1.2.6",
    "cron": "^4.4.0",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "fs-extra": "^11.3.3",
    "glob": "^11.1.0",
    "lodash-es": "^4.17.23",
    "p-queue": "^9.1.0",
    "push-all-in-one": "^4.5.1",
    "tslib": "^2.8.1",
    "yaml": "^2.8.2",
    "zx": "^8.8.5"
  },
  "pnpm": {
    "overrides": {
      "compare-func": "^2.0.0",
      "katex": "^0.16.21",
      "esbuild": "^0.25.0",
      "@octokit/plugin-paginate-rest": "^11.4.1",
      "@octokit/request": "^9.2.1",
      "@octokit/request-error": "^5.1.1",
      "brace-expansion": "^2.0.2",
      "tmp": "^0.2.4",
      "glob": "^11.1.0",
      "js-yaml": "^4.1.1"
    }
  },
  "type": "module",
  "changelog": {
    "language": "zh"
  }
}
